# Xcode (XcodeGen regenerates .xcodeproj from project.yml)
*.xcodeproj
build/
DerivedData/
*.xcworkspace/xcuserdata/
xcuserdata/

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# macOS
.DS_Store
*.swp
*.swo
*~

# IDE
.idea/
.vscode/

# App bundles (built artifacts)
*.app

# Claude / LOOP infrastructure (private — never expose in public repo)
# These files can live on disk and work locally; git must never see them.
# Pattern: gitignore is primary protection; pre-push hook is secondary.
.claude/
CLAUDE.md
hooks/                           # All hooks/ are LOOP private
scripts/cl-*.sh                  # CL learning scripts (cl-check, cl-seed, etc.)
scripts/claude-*.sh              # LOOP adapter scripts (claude-log-failure, etc.)
scripts/check-path-safety.sh    # LOOP path safety validator
scripts/test-launchd-env.sh     # LOOP launchd test utility
*.last-render-verify-at          # LOOP TV stamp files

# Session files — internal dev context, may contain PII (emails, account IDs)
SESSION-RESUME.md
.claude-checkpoint.md

# Private docs (not for public repo)
docs/LAUNCH-PLAN.md
docs/MARKET-ANALYSIS.md

# Personal/private docs
docs/personal/

# Research docs — safelist model: ignore everything, whitelist approved technical docs.
# Do NOT add strategy, adoption, competitive, financial, or business docs here.
# Approved docs must be explicitly force-tracked; any other research doc is private by default.
docs/research/*
!docs/research/e2e-perf-testing-approaches.md
!docs/research/editor-bug-analysis.md
!docs/research/ql-webview-sandbox-analysis.md
!docs/research/quicklook-extension-spm.md

# Smithery build artifacts and debug artifacts
npm/.smithery/
.smithery/

# Apple signing credentials
*.p8
*.provisionprofile
npm/.mcpregistry_github_token
npm/.mcpregistry_registry_token

# Release build artifacts (local only)
*.zip
*.tar.gz
docs/*.mov
docs/*.mp4
.release-preflight-passed-*
node_modules/
npm/node_modules/
npm/package-lock.json
npm/bin/

# Playwright
Tests/playwright/node_modules/
Tests/playwright/playwright-report/
Tests/playwright/test-results/
Tests/playwright/fixtures/.generated-at
# Commit fixtures (*.html) to git so CI runs without Swift build
# Regenerate with: bash scripts/gen-playwright-fixtures.sh
